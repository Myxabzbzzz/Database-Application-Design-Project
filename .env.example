# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=secret

# App keys — сгенерируй через: php artisan key:generate --show
AUTH_APP_KEY=
ORDER_APP_KEY=
PAYMENT_APP_KEY=
PRODUCT_APP_KEY=

# JWT — сгенерируй через: php artisan jwt:secret --show
JWT_SECRET=

# Gmail App Password — сгенерируй на myaccount.google.com/apppasswords (нужна 2FA)
GMAIL_APP_PASSWORD=
