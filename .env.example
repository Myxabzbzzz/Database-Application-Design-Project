# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=secret

# App keys — generate with: php artisan key:generate --show
AUTH_APP_KEY=
PAYMENT_APP_KEY=
PRODUCT_APP_KEY=
STORAGE_APP_KEY=

# JWT — generate with: php artisan jwt:secret --show  (inside service-auth)
JWT_SECRET=

# Shared secret between services (any random string)
INTERNAL_TOKEN=

# Gmail App Password — generate at myaccount.google.com/apppasswords (requires 2FA)
GMAIL_APP_PASSWORD=

# MinIO (leave as-is for local dev)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=storage
