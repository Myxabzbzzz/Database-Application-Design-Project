# ============================================================================
# E-Commerce Platform - Environment Configuration
# ============================================================================
#
# Copy this file to .env and fill in the required values.
#
# Quick Start:
#   1. cp .env.example .env
#   2. Fill in all required values marked with <REQUIRED>
#   3. docker-compose up -d
#
# See README.md "Environment Variables Reference" for detailed instructions.
#
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION
# ----------------------------------------------------------------------------
# Shared PostgreSQL credentials for all services.
# Each service has its own database (auth_db, product_db, payment_db).
#
# Default values work for local development.
# ⚠️  CHANGE IN PRODUCTION!

DB_USERNAME=postgres
DB_PASSWORD=secret

# ----------------------------------------------------------------------------
# LARAVEL APPLICATION KEYS
# ----------------------------------------------------------------------------
# Unique encryption key for each service.
#
# Generate with:
#   cd backend/service-auth && php artisan key:generate --show
#   cd backend/service-product && php artisan key:generate --show
#   cd backend/service-payment && php artisan key:generate --show
#   cd backend/service-storage && php artisan key:generate --show
#
# Format: base64:abcd1234...
# <REQUIRED>

AUTH_APP_KEY=
PAYMENT_APP_KEY=
PRODUCT_APP_KEY=
STORAGE_APP_KEY=

# ----------------------------------------------------------------------------
# JWT SECRET
# ----------------------------------------------------------------------------
# Secret key for signing JWT tokens (authentication).
#
# Generate with:
#   cd backend/service-auth
#   composer install
#   php artisan jwt:secret --show
#
# Format: Random string (e.g., abcd1234efgh5678...)
# <REQUIRED>

JWT_SECRET=

# ----------------------------------------------------------------------------
# INTERNAL SERVICE TOKEN
# ----------------------------------------------------------------------------
# Shared secret for authentication between backend services.
# Used when services communicate with each other (e.g., service-product → service-storage).
#
# Generate with:
#   openssl rand -base64 32
#
# Must be the same across all services.
# <REQUIRED>

INTERNAL_TOKEN=

# ----------------------------------------------------------------------------
# EMAIL CONFIGURATION (Gmail)
# ----------------------------------------------------------------------------
# Required for:
#   - User registration email verification
#   - Password reset emails
#   - Abandoned cart reminder emails
#
# Setup:
#   1. Enable 2-Factor Authentication in your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate a new App Password (16 characters)
#   4. Copy and paste below
#
# The email address (amir.boltabayev@gmail.com) is configured in docker-compose.yml.
# To use a different email, update docker-compose.yml:
#   - MAIL_USERNAME
#   - MAIL_FROM_ADDRESS
#
# Format: 16 lowercase letters (e.g., abcdabcdabcdabcd)
# <REQUIRED>

GMAIL_APP_PASSWORD=

# ----------------------------------------------------------------------------
# MINIO CONFIGURATION (S3-compatible Storage)
# ----------------------------------------------------------------------------
# MinIO is used for file storage (product images, designer photos, etc.).
#
# Default values work for local development.
# ⚠️  CHANGE IN PRODUCTION!
#
# Access MinIO Console:
#   http://localhost:9001
#   Login with these credentials

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=storage

# ----------------------------------------------------------------------------
# STRIPE CONFIGURATION (Optional)
# ----------------------------------------------------------------------------
# Required for payment processing via Stripe.
#
# Setup:
#   1. Create account at https://stripe.com
#   2. Go to https://dashboard.stripe.com/apikeys
#   3. Copy "Secret key" (starts with sk_test_ or sk_live_)
#   4. For webhooks:
#      - Go to https://dashboard.stripe.com/webhooks
#      - Add endpoint: http://your-domain/api/payment/webhook
#      - Select events: payment_intent.*, charge.refunded
#      - Copy "Signing secret" (starts with whsec_)
#
# Leave empty if not using payments.
# <OPTIONAL>

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# CONFIGURATION SUMMARY
# ----------------------------------------------------------------------------
#
# Required for Basic Functionality:
#   ✓ DB_USERNAME, DB_PASSWORD
#   ✓ AUTH_APP_KEY, PRODUCT_APP_KEY, PAYMENT_APP_KEY, STORAGE_APP_KEY
#   ✓ JWT_SECRET
#   ✓ INTERNAL_TOKEN
#   ✓ GMAIL_APP_PASSWORD
#
# Optional (leave empty if not needed):
#   ○ STRIPE_SECRET_KEY, STRIPE_WEBHOOK_SECRET
#
# Default Values (OK for development):
#   • MINIO_ROOT_USER, MINIO_ROOT_PASSWORD, MINIO_BUCKET
#
# ----------------------------------------------------------------------------
#
# Need Help?
#   - See README.md "Environment Variables Reference" section
#   - See README.md "Quick Start" section for step-by-step guide
#
# ============================================================================
